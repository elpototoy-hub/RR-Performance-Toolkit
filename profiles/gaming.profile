#!/bin/bash

# RR-Performance-Toolkit - Gaming Profile
# Optimized for gaming performance

echo "Loading gaming profile..."

# CPU settings - Maximum performance
CPU_GOVERNOR="performance"
CPU_MIN_FREQ=800000
CPU_MAX_FREQ=2400000

# GPU settings - Maximum
GPU_MODE="max"

# Memory settings
MEMORY_CACHE_TRIM=200
SWAPPINESS=30

# Background process limits
BACKGROUND_LIMIT=2

# Animation settings - Disable for better FPS
DISABLE_ANIMATIONS=true

# Screen settings
SCREEN_BRIGHTNESS=100
SCREEN_TIMEOUT=600

echo "Gaming profile loaded - Maximum performance mode"
